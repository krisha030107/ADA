#include <stdio.h>
#include <limits.h>

int minCoins(int coins[], int m, int amount)
{
    int dp[amount + 1];
    int i, j;

    dp[0] = 0;

    for (i = 1; i <= amount; i++)
        dp[i] = INT_MAX;

    for (i = 1; i <= amount; i++)
    {
        for (j = 0; j < m; j++)
        {
            if (coins[j] <= i)
            {
                int sub_res = dp[i - coins[j]];
                if (sub_res != INT_MAX && sub_res + 1 < dp[i])
                    dp[i] = sub_res + 1;
            }
        }
    }

    return dp[amount];
}

int main()
{
    int coins[] = {1, 2, 5};
    int m = sizeof(coins) / sizeof(coins[0]);
    int amount = 11;

    int result = minCoins(coins, m, amount);

    if (result == INT_MAX)
        printf("No solution\n");
    else
        printf("Minimum coins required: %d\n", result);

    return 0;
}
