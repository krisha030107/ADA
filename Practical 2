#include <stdio.h>
#include <stdlib.h>
#include <time.h>

void bubbleSort(int arr[], int n)
{
    int i, j, temp;
    for (i = 0; i < n - 1; i++)
    {
        for (j = 0; j < n - i - 1; j++)
        {
            if (arr[j] > arr[j + 1])
            {
                temp = arr[j];
                arr[j] = arr[j + 1];
                arr[j + 1] = temp;
            }
        }
    }
}

int main()
{
    int n = 10000;
    int *arr = (int *)malloc(n * sizeof(int));
    int i;

    for (i = 0; i < n; i++)
        arr[i] = rand();

    clock_t start, end;

    start = clock();
    bubbleSort(arr, n);
    end = clock();

    double time_taken = ((double)(end - start)) / CLOCKS_PER_SEC;

    printf("Execution Time: %f seconds\n", time_taken);

    free(arr);
    return 0;
}
